# Supabase Configuration
# Create a project at https://supabase.com/dashboard/
# Project Settings → API
#
# VITE_SUPABASE_ANON_KEY must be the "anon" / "public" key (JWT role "anon").
# NEVER put the "service_role" secret key here — it is blocked in browsers and
# breaks reads/writes with "Forbidden use of secret API key in browser".
VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Stripe Configuration
# Find these in your Stripe Developer Dashboard
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
